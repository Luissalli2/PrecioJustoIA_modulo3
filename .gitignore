# Config y skills locales de Claude Code — no se suben a GitHub
.claude/*
!.claude/skills/
.claude/skills/*
# ...salvo create-prd, que sí se versiona y comparte con el repo
!.claude/skills/create-prd/
!.claude/skills/conventional-commit/

# Resúmenes / apuntes del curso en Word — no se suben a GitHub
*.docx

# Notas de desarrollo — quedan locales, no se suben a GitHub
memorias_desarrollo_ia.md

# Dependencias y build de Next.js
/node_modules
/.next
/out
next-env.d.ts

# Base de datos SQLite: se genera sola al clonar (schema + seed), NO se versiona.
# Así el que baja el repo no recibe datos personales ni un binario que ensucia Git.
*.db
*.db-shm
*.db-wal

